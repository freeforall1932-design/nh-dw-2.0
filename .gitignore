```
# Dependencies
node_modules/

# Build artifacts
dist/
build/
target/

# TypeScript/JavaScript build output
*.js.map
*.tsbuildinfo

# Environment variables
.env
.env.local
*.env.*

# IDE files
.vscode/
.idea/
*.swp
*.swo

# Logs
*.log

# Temporary files
*.tmp

# Package lock files (already in source control but often changed)
package-lock.json

# Minified JavaScript (build output)
js/*.min.js

# Webpack output
webpack.config.js
```