coverage/
htmlcov/
*.coverage

# Testing
.nyc_output/
coverage/lcov-report/

# Bower
bower_components/

# Grunt
.grunt/
grunt-cache/

# Node
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Temporary files
*.bak
*.tmp
*.temp
